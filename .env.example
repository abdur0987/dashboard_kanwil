# Local development uses SQLite automatically when Turso env vars are empty.
SQLITE_DB_PATH=./data/dashboard.sqlite

# Production Turso/libSQL database.
# Create these with Turso CLI, then set them in your deployment provider.
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Better Auth.
BETTER_AUTH_URL=https://your-production-domain.example
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-production-domain.example
